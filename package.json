{
  "name": "ng-smart-table-workspace",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build:demo": "ng build demo --configuration production",
    "build:lib": "ng build ng2-smart-table",
    "build:ci": "npm run build:lib && npm run build:demo && npm run test:ci",
    "docs:gh-pages": "npm run build:demo -- --base-href '/ng2-smart-table/' && npx angular-cli-ghpages --dir=dist/demo",
    "test": "ng test ng2-smart-table",
    "test:ci": "ng test ng2-smart-table --no-watch --browsers=ChromeHeadless",
    "test:demo": "ng test demo --no-watch --browsers=ChromeHeadless",
    "lint": "ng lint",
    "pack:lib": "npm run build:lib && mkdir -p dist-pack && npm pack ./dist/ng2-smart-table --pack-destination dist-pack",
    "consumer:smoke": "bash scripts/consumer-smoke.sh",
    "release": "npm run build:lib && npm run publish:dist",
    "publish:dist": "npm publish --access=public ./dist/ng2-smart-table",
    "publish:beta": "bash scripts/publish-beta.sh",
    "audit:pack": "bash scripts/audit-pack.sh",
    "changelog": "standard-changelog -p angular"
  },
  "devDependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular-eslint/builder": "^18.4.0",
    "@angular-eslint/eslint-plugin": "^18.4.0",
    "@angular-eslint/eslint-plugin-template": "^18.4.0",
    "@angular-eslint/template-parser": "^18.4.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@types/jasmine": "~5.1.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.14.10",
    "angular-cli-ghpages": "^2.0.1",
    "eslint": "^8.57.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "highlight.js": "^11.10.0",
    "lodash-es": "^4.17.21",
    "ng-packagr": "^18.2.0",
    "rxjs": "~7.8.1",
    "standard-changelog": "^2.0.27",
    "tslib": "^2.6.3",
    "typescript": "~5.5.4",
    "zone.js": "~0.14.10"
  }
}
