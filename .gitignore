# See http://help.github.com/ignore-files/ for more about ignoring files.

# --- Dependencies ---
/node_modules

# --- Angular / CLI ---
.angular/
**/.angular/

# compiled output (workspace)
/dist
/tmp
/out-tsc
**/.ng_pkg_build

# Only exists if Bazel was run
/bazel-out

# --- Tests & coverage ---
/coverage
**/coverage
libpeerconnection.log
testem.log

# --- Profiling ---
chrome-profiler-events.json
speed-measure-plugin.json

# --- npm / pack ---
*.tgz
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist-pack/
consumer-smoke/node_modules/
consumer-smoke/dist/
consumer-smoke/package-lock.json

# --- TypeScript / tooling ---
*.tsbuildinfo
.eslintcache

# --- IDEs and editors ---
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# --- misc ---
/.sass-cache
/connect.lock
/typings

# --- Local env (secrets / machine-specific) ---
.env
.env.*.local
!.env.example

# --- System files ---
.DS_Store
Thumbs.db
